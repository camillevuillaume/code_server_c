{
    # Global options
    http_port 80
    https_port 443
    email camillevuillaume@gmail.com
}

# Main domain with automatic SSL
codingtest.dev {
    # Use Let's Encrypt with DNS validation through Porkbun
    tls {
        dns porkbun {
            api_key {env.PORKBUN_API_KEY} 
            api_secret_key {env.PORKBUN_SECRET_API_KEY}
        }
    }

    # Reverse proxy to the backend service
    reverse_proxy localhost:8443
    
    # Logging
    log {
        output file /data/access.log
        format json
    }
    
}

# Redirect HTTP to HTTPS
http://codingtest.dev {
    redir https://codingtest.dev{uri} 301
}


